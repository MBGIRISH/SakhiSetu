# SakhiSetu Configuration
# Copy to .env and adjust as needed

# Application
APP_NAME=SakhiSetu
DEBUG=false

# Database (SQLite for dev; use PostgreSQL for production)
DATABASE_URL=sqlite:///./sakhisetu.db

# Scraper - URLs to scrape (comma-separated for multiple sources)
SCRAPE_URL=https://wcd.nic.in/schemes
SCRAPE_URLS=https://www.india.gov.in/my-government/schemes,https://www.myscheme.gov.in/,https://www.india.gov.in/,https://wcd.nic.in/schemes

# Auto-scrape interval in hours (0 = disabled, 24 = daily)
AUTO_SCRAPE_HOURS=24

# Playwright for JS-rendered sites (india.gov.in, myscheme.gov.in)
USE_PLAYWRIGHT=true

# API sources (optional)
USE_APIS=true
DATA_GOV_IN_API_KEY=
APISETU_CONSUMER_KEY=

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# RAG Chatbot (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

RAG_TOP_K=5

# Multilingual (en, hi, ta, te, mr, bn, gu, kn, ml, pa)
DEFAULT_LANGUAGE=en
